# Supabase (required for auth, forum, votes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron jobs — protected by CRON_SECRET header (x-cron-secret)
# Scheduled via n8n workflow workflows/n8n/app-cron.workflow.ts (not Vercel Cron; Hobby plan has no cron)
CRON_SECRET=

# n8n webhooks
N8N_AI_SUMMARY_WEBHOOK_URL=
N8N_FORUM_PROMPTS_WEBHOOK_URL=

# Forum admin (comma-separated emails)
FORUM_ADMIN_EMAILS=

# Email (notifications, welcome)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stortinget API defaults
STORTINGET_SESSION_ID=2025-2026
STORTINGET_PERIODE_ID=2021-2025
NEXT_PUBLIC_STORTINGET_SESSION_ID=2025-2026
NEXT_PUBLIC_STORTINGET_PERIODE_ID=2021-2025

# Dev only
DISABLE_HMR=
