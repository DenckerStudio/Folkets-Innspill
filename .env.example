# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# =============================================================================
# OAuth Providers (configure in Supabase Dashboard → Authentication → Providers)
# =============================================================================
# Google: enable in Supabase Dashboard, set redirect URL to {YOUR_URL}/api/auth/callback
# Reddit: enable in Supabase Dashboard, set redirect URL to {YOUR_URL}/api/auth/callback

# =============================================================================
# AI (optional — AI summaries fall back gracefully without this)
# =============================================================================
GEMINI_API_KEY=""

# Ollama (alternative to Gemini)
NEXT_PUBLIC_OLLAMA_URL=""
NEXT_PUBLIC_OLLAMA_MODEL="llama3"

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
